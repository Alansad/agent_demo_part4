# ============================================================
# Agent Demo Week 5-6 — 环境变量配置
# 复制此文件为 .env，填入你的配置后启动服务
# ============================================================

# ── LLM API Key（必填）──────────────────────────────────────
# Anthropic 官方 Key，以 sk-ant- 开头
LLM_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── API 地址（可选）─────────────────────────────────────────
# 留空则使用 Anthropic 官方地址 https://api.anthropic.com
# 如使用代理或第三方兼容接口，填入完整 baseURL，例如：
# LLM_BASE_URL=https://your-proxy.example.com/v1
LLM_BASE_URL=

# ── 模型（可选）─────────────────────────────────────────────
# 默认：claude-opus-4-6
# 可选：claude-sonnet-4-6 / claude-haiku-4-5-20251001
# 注意：扩展思考（Extended Thinking）仅 Opus/Sonnet 系列支持
LLM_MODEL=claude-opus-4-6

# ── 服务端口（可选，默认 3000）──────────────────────────────
PORT=3000
